    "formula_channels": [
      {
        "name": "coolant",
        "formula": "(coolantRaw - 40) * 1.8 + 32",
        "units": null,
        "digits": null
      },
      {
        "name": "iat",
        "formula": "(iatRaw - 40) * 1.8 + 32",
        "units": null,
        "digits": null
      },
      {
        "name": "fuelTemp",
        "formula": "(fuelTempRaw - 40) * 1.8 + 32",
        "units": null,
        "digits": null
      },
      {
        "name": "time",
        "formula": "timeNow",
        "units": null,
        "digits": null
      },
      {
        "name": "seconds",
        "formula": "secl",
        "units": null,
        "digits": null
      },
      {
        "name": "fuelPressure_bar",
        "formula": "fuelPressure * 0.06894757",
        "units": null,
        "digits": null
      },
      {
        "name": "oilPressure_bar",
        "formula": "oilPressure * 0.06894757",
        "units": null,
        "digits": null
      },
      {
        "name": "fuelPressure_kpa",
        "formula": "fuelPressure * 6.894757",
        "units": null,
        "digits": null
      },
      {
        "name": "oilPressure_kpa",
        "formula": "oilPressure  * 6.894757",
        "units": null,
        "digits": null
      },
      {
        "name": "throttle",
        "formula": "tps",
        "units": "%",
        "digits": null
      },
      {
        "name": "revolutionTime",
        "formula": "rpm ? ( 60000.0 / rpm) : 0",
        "units": null,
        "digits": null
      },
      {
        "name": "strokeMultipler",
        "formula": "twoStroke == 1 ? 1 : 2",
        "units": null,
        "digits": null
      },
      {
        "name": "cycleTime",
        "formula": "revolutionTime * strokeMultipler",
        "units": null,
        "digits": null
      },
      {
        "name": "pulseLimit",
        "formula": "cycleTime / nSquirts",
        "units": null,
        "digits": null
      },
      {
        "name": "nFuelChannels",
        "formula": "arrayValue( array.boardFuelOutputs, pinLayout )",
        "units": null,
        "digits": null
      },
      {
        "name": "nIgnChannels",
        "formula": "arrayValue( array.boardIgnOutputs, pinLayout )",
        "units": null,
        "digits": null
      },
      {
        "name": "sequentialFuelAvailable",
        "formula": "nCylinders <= nFuelChannels",
        "units": null,
        "digits": null
      },
      {
        "name": "sequentialIgnitionAvailable",
        "formula": "nCylinders <= nIgnChannels",
        "units": null,
        "digits": null
      },
      {
        "name": "dutyCycle",
        "formula": "rpm ? ( 100.0*pulseWidth/pulseLimit ) : 0",
        "units": null,
        "digits": null
      },
      {
        "name": "stgDutyCycle",
        "formula": "rpm && stagingEnabled ? ( 100.0*pulseWidth3/pulseLimit ) : 0",
        "units": null,
        "digits": null
      },
      {
        "name": "boostCutOut",
        "formula": "boostCutFuel || boostCutSpark",
        "units": null,
        "digits": null
      },
      {
        "name": "lambda",
        "formula": "afr / stoich",
        "units": null,
        "digits": null
      },
      {
        "name": "lambdaTarget",
        "formula": "afrTarget / stoich",
        "units": null,
        "digits": null
      },
      {
        "name": "MAPxRPM",
        "formula": "rpm * map",
        "units": null,
        "digits": null
      },
      {
        "name": "loopsPerRev",
        "formula": "rpm ? loopsPerSecond / (rpm / 60) : 0",
        "units": null,
        "digits": null
      },
      {
        "name": "req_fuel",
        "formula": "reqFuel",
        "units": null,
        "digits": null
      },
      {
        "name": "bat_correction",
        "formula": "battVCorMode ? 100 : batCorrection",
        "units": null,
        "digits": null
      },
      {
        "name": "inj_open",
        "formula": "battVCorMode ? ((injOpen * batCorrection) / 100) : injOpen",
        "units": null,
        "digits": null
      },
      {
        "name": "ase_enrich",
        "formula": "ASECurr",
        "units": null,
        "digits": null
      },
      {
        "name": "map_multiply_amt",
        "formula": "multiplyMAP ? map : 100",
        "units": null,
        "digits": null
      },
      {
        "name": "map_bar",
        "formula": "(map - baro) / 101.33",
        "units": null,
        "digits": null
      },
      {
        "name": "map_psi",
        "formula": "(map - baro) * 0.145038",
        "units": null,
        "digits": null
      },
      {
        "name": "map_inhg",
        "formula": "(baro - map) * 0.2953007",
        "units": null,
        "digits": null
      },
      {
        "name": "map_vacboost",
        "formula": "map < baro ? -map_inhg : map_psi",
        "units": null,
        "digits": null
      },
      {
        "name": "vssMPH",
        "formula": "vss / 1.60934",
        "units": null,
        "digits": null
      },
      {
        "name": "fuelLoadMax",
        "formula": "(algorithm == 0 || algorithm == 2) ? 511 : 100.0",
        "units": null,
        "digits": null
      },
      {
        "name": "ignLoadMax",
        "formula": "(ignAlgorithm == 0 || ignAlgorithm == 2) ? 511 : 100.0",
        "units": null,
        "digits": null
      },
      {
        "name": "fuel2LoadMax",
        "formula": "(fuel2Algorithm == 0 || fuel2Algorithm == 2) ? 511 : 100.0",
        "units": null,
        "digits": null
      },
      {
        "name": "ign2LoadMax",
        "formula": "(spark2Algorithm == 0 || spark2Algorithm == 2) ? 511 : 100.0",
        "units": null,
        "digits": null
      },
      {
        "name": "ign2ValuesMin",
        "formula": "(spark2Mode == 1) ? 0 : -40",
        "units": null,
        "digits": null
      },
      {
        "name": "ign2ValuesMax",
        "formula": "(spark2Mode == 1) ? 215 : 70",
        "units": null,
        "digits": null
      },
      {
        "name": "fuelLoad2",
        "formula": "fuel2Algorithm == 0 ? map : fuel2Algorithm == 1 ? tps : fuel2Algorithm == 2 ? 0 : 0",
        "units": null,
        "digits": null
      },
      {
        "name": "ignLoad2",
        "formula": "spark2Algorithm == 0 ? map : spark2Algorithm == 1 ? tps : spark2Algorithm == 2 ? 0 : ignLoad",
        "units": null,
        "digits": null
      },
      {
        "name": "vvtLoad",
        "formula": "(vvtLoadSource == 0) ? map : tps",
        "units": null,
        "digits": null
      },
      {
        "name": "vvtLoadMax",
        "formula": "(vvtLoadSource == 0) ? 511 : 100.0",
        "units": null,
        "digits": null
      },
      {
        "name": "wmiLoadMax",
        "formula": "(wmiMode == 2) ? 100.0 : 255",
        "units": null,
        "digits": null
      },
      {
        "name": "idleRes",
        "formula": "(iacAlgorithm == 5 || iacAlgorithm == 7) ? 3.0 : 1.0",
        "units": null,
        "digits": null
      },
      {
        "name": "idleResMax",
        "formula": "(iacAlgorithm == 5 || iacAlgorithm == 7) ? (iacStepHome-3) : 100.0",
        "units": null,
        "digits": null
      },
      {
        "name": "vvtLoadRes",
        "formula": "(vvtLoadSource == 0) ? 2.000 : 0.500",
        "units": null,
        "digits": null
      },
      {
        "name": "wmiLoadRes",
        "formula": "(wmiMode >= 2) ? 0.5 : 1.0",
        "units": null,
        "digits": null
      },
      {
        "name": "fuelLoadRes",
        "formula": "((algorithm == 0) || (algorithm == 2)) ? 2.000 : 0.500",
        "units": null,
        "digits": null
      },
      {
        "name": "ignLoadRes",
        "formula": "((ignAlgorithm == 0) || (ignAlgorithm == 2)) ? 2.000 : 0.500",
        "units": null,
        "digits": null
      },
      {
        "name": "fuelLoadFeedBack",
        "formula": "((algorithm == 0) || (algorithm == 2)) ? 1.000 : 0.250",
        "units": null,
        "digits": null
      },
      {
        "name": "ignLoadFeedBack",
        "formula": "((ignAlgorithm == 0) || (ignAlgorithm == 2)) ? 1.000 : 0.250",
        "units": null,
        "digits": null
      },
      {
        "name": "fuel2LoadRes",
        "formula": "((fuel2Algorithm  == 0) || (fuel2Algorithm  == 2)) ? 2.000 : 0.500",
        "units": null,
        "digits": null
      },
      {
        "name": "ign2LoadRes",
        "formula": "((spark2Algorithm == 0) || (spark2Algorithm == 2)) ? 2.000 : 0.500",
        "units": null,
        "digits": null
      },
      {
        "name": "vvtDecimalRes",
        "formula": "(vvtLoadSource == 0) ? 0 : 1",
        "units": null,
        "digits": null
      },
      {
        "name": "fuelDecimalRes",
        "formula": "((algorithm == 0) || (algorithm == 2)) ? 0 : 1",
        "units": null,
        "digits": null
      },
      {
        "name": "ignDecimalRes",
        "formula": "((ignAlgorithm == 0) || (ignAlgorithm == 2)) ? 0 : 1",
        "units": null,
        "digits": null
      },
      {
        "name": "fuel2DecimalRes",
        "formula": "((fuel2Algorithm  == 0) || (fuel2Algorithm  == 2)) ? 0 : 1",
        "units": null,
        "digits": null
      },
      {
        "name": "ign2DecimalRes",
        "formula": "((spark2Algorithm == 0) || (spark2Algorithm == 2)) ? 0 : 1",
        "units": null,
        "digits": null
      },
      {
        "name": "boostTableLimit",
        "formula": "boostType == 0 ? 100.0 : 511",
        "units": null,
        "digits": null
      },
      {
        "name": "CLIdleDelta",
        "formula": "CLIdleTarget - rpm",
        "units": null,
        "digits": null
      },
      {
        "name": "syncStatus",
        "formula": "halfSync + (sync << 1)",
        "units": null,
        "digits": null
      },
      {
        "name": "CANisAvailable",
        "formula": "(enable_secondarySerial && (secondarySerialProtocol == 2))",
        "units": null,
        "digits": null
      }
    ]
  },
